# Normalize text files and let Git handle platform-specific working-tree line endings.
* text=auto

# Shell scripts must stay LF so bash/sh tooling remains portable.
*.sh text eol=lf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.nupkg binary
*.snupkg binary
