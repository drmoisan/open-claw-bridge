# Copy this file to .env and update the placeholders for your Windows host.

OpenClaw__HostAdapter__BaseUrl=http://host.docker.internal:4319/v1
OpenClaw__HostAdapter__TokenFile=/run/openclaw/hostadapter.token
OpenClaw__Polling__MessagesIntervalSeconds=60
OpenClaw__Polling__MeetingRequestsIntervalSeconds=60
OpenClaw__Polling__CalendarIntervalSeconds=300
OpenClaw__Polling__MessageLookbackHours=48
OpenClaw__Polling__CalendarPastDays=14
OpenClaw__Polling__CalendarFutureDays=30
OpenClaw__Defaults__Limit=100
OpenClaw__Defaults__MaxLimit=250
OPENCLAW_HTTP_PORT=8080
OPENCLAW_DEV_HTTP_PORT=8082
HOSTADAPTER_TOKEN_FILE=C:\ProgramData\OpenClaw\HostAdapter\adapter.token
ASPNETCORE_ENVIRONMENT=Production

# OpenClaw Agent (required container service)
# Image published at https://github.com/openclaw/openclaw/pkgs/container/openclaw.
# The compose stack builds a local wrapper image from this upstream base and
# bakes the assistant workspace into the container image.
OPENCLAW_AGENT_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_AGENT_PORT=18789

# OpenClaw gateway dashboard shared secret. Produced by scripts/Invoke-OpenClawAgentOnboarding.ps1.
# Run the onboarding script once to populate this value. Compose does not provide a default;
# leaving it empty after onboarding will fail-fast on start.
OPENCLAW_GATEWAY_TOKEN=

# Anthropic credential for the openclaw-agent runtime.
# Obtain your API key from https://console.anthropic.com.
# Supply the real value in secrets/.env.anthropic (gitignored). Never commit the real key here.
ANTHROPIC_API_KEY=

# Model used by the admin-assistant agent. Verify the current model ID at docs.openclaw.ai/providers/anthropic.
OPENCLAW_AGENT_MODEL=anthropic/claude-opus-4-6
