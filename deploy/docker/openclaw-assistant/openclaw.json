{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "auto",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6"
        ]
      }
    },
    "list": [
      {
        "id": "admin-assistant",
        "workspace": "/workspace",
        "skills": [
          "mailbridge_admin"
        ]
      }
    ]
  },
  "plugins": {
    "entries": {
      "firecrawl": {
        "config": {
          "webSearch": {
            "apiKey": "${WEB_SEARCH_API_KEY}"
          }
        }
      }
    }
  }
}